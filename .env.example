# Copy to .env to override. All variables are optional; defaults below match production.

# Where SQLite + vector matrix live.
RAG_NANO_INDEX_DIR=./.rag-nano

# Embedding configuration
RAG_NANO_EMBEDDING_BACKEND=local        # local | mock
RAG_NANO_EMBEDDING_MODEL=intfloat/multilingual-e5-base
RAG_NANO_EMBEDDING_DIM=768              # only used by mock backend

# Component backends
RAG_NANO_VECTOR_STORE=numpy_flat        # numpy_flat | in_memory
RAG_NANO_STRUCTURED_STORE=sqlite        # sqlite | in_memory
RAG_NANO_RERANKER=identity              # identity only in v1

# Chunking
RAG_NANO_MARKDOWN_CHUNK_SIZE=800        # chars per chunk
RAG_NANO_MARKDOWN_CHUNK_OVERLAP=100
RAG_NANO_CODE_CHUNK_LINES=80
RAG_NANO_CODE_CHUNK_OVERLAP_LINES=10

# Ingest gate
RAG_NANO_OVERSIZED_CONVERSATION_BYTES=131072   # 128 KiB

# HTTP server
RAG_NANO_HTTP_HOST=127.0.0.1
RAG_NANO_HTTP_PORT=8089

# Retrieval defaults
RAG_NANO_DEFAULT_K=5
RAG_NANO_MAX_K=50
RAG_NANO_RECALL_CANDIDATE_MULTIPLIER=4   # debug.recall_candidates returns multiplier * k

# Logging
RAG_NANO_LOG_LEVEL=INFO
